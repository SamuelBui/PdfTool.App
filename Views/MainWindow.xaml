<Window x:Class="PdfTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Utility Tool"
        Height="860"
        Width="1320"
        MinHeight="760"
        MinWidth="1160"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#FFF4F6F8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SubtlePanelBrush" Color="#FFF7FAFC" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD6DFE5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0B6E99" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF1D7D46" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFB54708" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFC43C35" />

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF344054" />
            <Setter Property="Background" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEFF4F7" />
                    <Setter Property="BorderBrush" Value="#FFB9CBD7" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFE1EAF0" />
                    <Setter Property="BorderBrush" Value="#FF98AFBC" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFF5F7FA" />
                    <Setter Property="BorderBrush" Value="#FFE5EAF0" />
                    <Setter Property="Foreground" Value="#FF98A2B3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4,4,4,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF344054" />
            <Setter Property="Background" Value="#FFF8FAFC" />
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,8,6,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LastOperationSucceeded}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOperationSucceeded}" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="InlinePasswordHostStyle" TargetType="Border">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="InlinePasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6,36,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="InlineTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6,36,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="PasswordStrengthLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,4,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF667085" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Weak">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Fair">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Strong">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Very strong">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SubtlePanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="CompactFieldTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF344054" />
        </Style>

        <Style x:Key="CompactHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinWidth" Value="128" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF095D81" />
                    <Setter Property="BorderBrush" Value="#FF095D81" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF074E6B" />
                    <Setter Property="BorderBrush" Value="#FF074E6B" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFD0E2EB" />
                    <Setter Property="BorderBrush" Value="#FFD0E2EB" />
                    <Setter Property="Foreground" Value="#FFEEF4F7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFF1F0" />
            <Setter Property="BorderBrush" Value="#FFF2C2BF" />
            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
        </Style>

        <Style x:Key="UtilityActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFF4F7FA" />
            <Setter Property="BorderBrush" Value="#FFD6DFE5" />
            <Setter Property="MinWidth" Value="96" />
        </Style>

        <Style x:Key="ActionToolbarStyle" TargetType="WrapPanel">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>

        <Style x:Key="SegmentedHostStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF3F6F8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style x:Key="SegmentedRadioButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF475467" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="#FFEAF2F6" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chip" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
</Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Control"
                    Command="{Binding Merge.UndoCommand}" />
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                <TabItem Header="Protect PDF">
                    <Grid Margin="8" DataContext="{Binding Protect}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="304" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,12,0">
                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource CompactCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="Action" />
                                                <Border Style="{StaticResource SegmentedHostStyle}" Margin="0,8,0,0">
                                                    <UniformGrid Columns="2">
                                                        <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Protect PDF" IsChecked="{Binding IsProtectAction}" />
                                                        <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Unlock PDF" IsChecked="{Binding IsUnlockAction}" />
                                                    </UniformGrid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource CompactCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="{Binding BatchModeTitle}" />
                                                <Border Style="{StaticResource SegmentedHostStyle}" Margin="0,8,0,0">
                                                    <UniformGrid Columns="3">
                                                        <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Single file" IsChecked="{Binding IsSingleMode}" />
                                                        <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Multiple files" IsChecked="{Binding IsMultipleMode}" />
                                                        <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Folder" IsChecked="{Binding IsFolderMode}" />
                                                    </UniformGrid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0"
                                                Grid.Column="2"
                                                Style="{StaticResource CompactCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="Run" />
                                                <Button Margin="0,8,0,0"
                                                        Height="40"
                                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                                        Content="{Binding ExecuteActionLabel}"
                                                        Command="{Binding ProtectCommand}" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="3"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource StatusTextStyle}"
                                                   Text="{Binding StatusMessage}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}"
                                        Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Text="Single File" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Input PDF:" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseInputCommand}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Output PDF:" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="2" Grid.Column="2" Content="Save As" Command="{Binding BrowseOutputCommand}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Passwords" />

                                        <Grid Margin="0,4,0,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleMode}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnlockAction}" Value="True">
                                                                <Setter Property="Grid.ColumnSpan" Value="2" />
                                                                <Setter Property="Margin" Value="0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="{Binding PrimaryPasswordLabel}" />
                                                    <TextBlock Style="{StaticResource CompactHintTextStyle}" Text="{Binding UserPasswordStrengthGuidance}" />
                                                    <Border Style="{StaticResource InlinePasswordHostStyle}" Margin="0,10,0,0">
                                                        <Grid>
                                                            <PasswordBox x:Name="ProtectUserPasswordBoxCompact"
                                                                         PasswordChanged="ProtectUserPasswordBox_OnPasswordChanged">
                                                                <PasswordBox.Style>
                                                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource InlinePasswordBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUserPasswordVisible}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </PasswordBox.Style>
                                                            </PasswordBox>
                                                            <TextBox Text="{Binding UserPassword, UpdateSourceTrigger=PropertyChanged}">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUserPasswordVisible}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                            <Button Style="{StaticResource EyeButtonStyle}"
                                                                    Click="ProtectToggleUserPasswordVisibility_OnClick">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                                              Stroke="#FF475467"
                                                                              StrokeThickness="1.8"
                                                                              Fill="Transparent" />
                                                                        <Ellipse Canvas.Left="8.2"
                                                                                 Canvas.Top="8.2"
                                                                                 Width="7.6"
                                                                                 Height="7.6"
                                                                                 Stroke="#FF475467"
                                                                                 StrokeThickness="1.8"
                                                                                 Fill="Transparent" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Grid.Column="0"
                                                                     Height="6"
                                                                     Minimum="0"
                                                                     Maximum="4"
                                                                     Value="{Binding UserPasswordStrengthScore}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Style="{StaticResource PasswordStrengthLabelStyle}"
                                                                   Text="{Binding UserPasswordStrengthLabel}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
                                                        <Setter Property="Margin" Value="8,0,0,0" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnlockAction}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="Owner password" />
                                                    <TextBlock Style="{StaticResource CompactHintTextStyle}" Text="Optional unless you restrict permissions." />
                                                    <Border Style="{StaticResource InlinePasswordHostStyle}" Margin="0,10,0,0">
                                                        <Grid>
                                                            <PasswordBox x:Name="ProtectOwnerPasswordBoxCompact"
                                                                         PasswordChanged="ProtectOwnerPasswordBox_OnPasswordChanged">
                                                                <PasswordBox.Style>
                                                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource InlinePasswordBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </PasswordBox.Style>
                                                            </PasswordBox>
                                                            <TextBox Text="{Binding OwnerPassword, UpdateSourceTrigger=PropertyChanged}">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                            <Button Style="{StaticResource EyeButtonStyle}"
                                                                    Click="ProtectToggleOwnerPasswordVisibility_OnClick">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                                              Stroke="#FF475467"
                                                                              StrokeThickness="1.8"
                                                                              Fill="Transparent" />
                                                                        <Ellipse Canvas.Left="8.2"
                                                                                 Canvas.Top="8.2"
                                                                                 Width="7.6"
                                                                                 Height="7.6"
                                                                                 Stroke="#FF475467"
                                                                                 StrokeThickness="1.8"
                                                                                 Fill="Transparent" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Grid.Column="0"
                                                                     Height="6"
                                                                     Minimum="0"
                                                                     Maximum="4"
                                                                     Value="{Binding OwnerPasswordStrengthScore}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Style="{StaticResource PasswordStrengthLabelStyle}"
                                                                   Text="{Binding OwnerPasswordStrengthLabel}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Margin="0,4,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Margin="0,0,8,0"
