<Window x:Class="PdfTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Utility Tool v0.2"
        Height="860"
        Width="1320"
        MinHeight="760"
        MinWidth="1160"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#FFF4F6F8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SubtlePanelBrush" Color="#FFF7FAFC" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD6DFE5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0B6E99" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF1D7D46" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFB54708" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFC43C35" />

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="6" />
        </Style>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,8,6,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LastOperationSucceeded}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOperationSucceeded}" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="InlinePasswordHostStyle" TargetType="Border">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="InlinePasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6,36,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="InlineTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6,36,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="PasswordStrengthLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,4,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF667085" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Weak">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Fair">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Strong">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Very strong">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
</Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Control"
                    Command="{Binding Merge.UndoCommand}" />
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <TabControl>
                <TabItem Header="Protect PDF">
                    <Grid Margin="8" DataContext="{Binding Protect}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,16,0">
                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Protect Mode" />
                                        <WrapPanel>
                                            <RadioButton Content="Single file" IsChecked="{Binding IsSingleMode}" Margin="6" />
                                            <RadioButton Content="Multiple files" IsChecked="{Binding IsMultipleMode}" Margin="6" />
                                            <RadioButton Content="Folder" IsChecked="{Binding IsFolderMode}" Margin="6" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}"
                                        Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Text="Single File" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Input PDF:" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseInputCommand}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Output PDF:" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="2" Grid.Column="2" Content="Save As" Command="{Binding BrowseOutputCommand}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Text="Passwords" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="User password:" Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <Border Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{StaticResource InlinePasswordHostStyle}"
                                                Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid>
                                                <PasswordBox x:Name="ProtectUserPasswordBox"
                                                         PasswordChanged="ProtectUserPasswordBox_OnPasswordChanged">
                                                <PasswordBox.Style>
                                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource InlinePasswordBoxStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUserPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </PasswordBox.Style>
                                            </PasswordBox>
                                            <TextBox Text="{Binding UserPassword, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUserPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Style="{StaticResource EyeButtonStyle}"
                                                    Click="ProtectToggleUserPasswordVisibility_OnClick">
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                              Stroke="#FF475467"
                                                              StrokeThickness="1.8"
                                                              Fill="Transparent" />
                                                        <Ellipse Canvas.Left="8.2"
                                                                 Canvas.Top="8.2"
                                                                 Width="7.6"
                                                                 Height="7.6"
                                                                 Stroke="#FF475467"
                                                                 StrokeThickness="1.8"
                                                                 Fill="Transparent" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,6"
                                                    Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ProgressBar Margin="6,0,6,0"
                                                         Height="8"
                                                         Minimum="0"
                                                         Maximum="4"
                                                         Value="{Binding UserPasswordStrengthScore}" />
                                            <TextBlock Style="{StaticResource PasswordStrengthLabelStyle}"
                                                       Text="{Binding UserPasswordStrengthLabel}" />
                                            <TextBlock Margin="6,0,6,0"
                                                       Foreground="#FF667085"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding UserPasswordStrengthGuidance}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Common Password:">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Row="3" Grid.Column="1">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource InlinePasswordHostStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                            <PasswordBox x:Name="ProtectCommonPasswordBox"
                                                         PasswordChanged="ProtectCommonPasswordBox_OnPasswordChanged">
                                                <PasswordBox.Style>
                                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource InlinePasswordBoxStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCommonPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </PasswordBox.Style>
                                            </PasswordBox>
                                            <TextBox Text="{Binding BatchCommonPassword, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCommonPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Style="{StaticResource EyeButtonStyle}"
                                                    Click="ProtectToggleCommonPasswordVisibility_OnClick">
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                              Stroke="#FF475467"
                                                              StrokeThickness="1.8"
                                                              Fill="Transparent" />
                                                        <Ellipse Canvas.Left="8.2"
                                                                 Canvas.Top="8.2"
                                                                 Width="7.6"
                                                                 Height="7.6"
                                                                 Stroke="#FF475467"
                                                                 StrokeThickness="1.8"
                                                                 Fill="Transparent" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <ProgressBar Margin="6,0,6,0"
                                                         Height="8"
                                                         Minimum="0"
                                                         Maximum="4"
                                                         Value="{Binding CommonPasswordStrengthScore}" />
                                            <TextBlock Style="{StaticResource PasswordStrengthLabelStyle}"
                                                       Text="{Binding CommonPasswordStrengthLabel}" />
                                            <TextBlock Margin="6,0,6,0"
                                                       Foreground="#FF667085"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding CommonPasswordStrengthGuidance}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Owner password:" />
                                        <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource InlinePasswordHostStyle}">
                                            <Grid>
                                            <PasswordBox x:Name="ProtectOwnerPasswordBox"
                                                         PasswordChanged="ProtectOwnerPasswordBox_OnPasswordChanged">
                                                <PasswordBox.Style>
                                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource InlinePasswordBoxStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </PasswordBox.Style>
                                            </PasswordBox>
                                            <TextBox Text="{Binding OwnerPassword, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Style="{StaticResource EyeButtonStyle}"
                                                    Click="ProtectToggleOwnerPasswordVisibility_OnClick">
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                              Stroke="#FF475467"
                                                              StrokeThickness="1.8"
                                                              Fill="Transparent" />
                                                        <Ellipse Canvas.Left="8.2"
                                                                 Canvas.Top="8.2"
                                                                 Width="7.6"
                                                                 Height="7.6"
                                                                 Stroke="#FF475467"
                                                                 StrokeThickness="1.8"
                                                                 Fill="Transparent" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Row="6" Grid.Column="1">
                                            <ProgressBar Margin="6,0,6,0"
                                                         Height="8"
                                                         Minimum="0"
                                                         Maximum="4"
                                                         Value="{Binding OwnerPasswordStrengthScore}" />
                                            <TextBlock Style="{StaticResource PasswordStrengthLabelStyle}"
                                                       Text="{Binding OwnerPasswordStrengthLabel}" />
                                            <TextBlock Margin="6,0,6,0"
                                                       Foreground="#FF667085"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding OwnerPasswordStrengthGuidance}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="7"
                                                   Grid.Column="1"
                                                   Margin="6,4,6,0"
                                                   Foreground="#FF667085"
                                           Text="Owner password becomes required when you disable any permission below." />
                                    </Grid>
                                </Border>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SectionBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Batch Strategy" />
                                        <WrapPanel>
                                            <RadioButton Content="One password for all" IsChecked="{Binding IsOnePasswordForAll}" Margin="6" />
                                            <RadioButton Content="One password per file" IsChecked="{Binding IsOnePasswordPerFile}" Margin="6" />
                                            <RadioButton Content="Import mapping from CSV/Excel" IsChecked="{Binding IsImportMappingMode}" Margin="6" />
                                        </WrapPanel>

                                        <WrapPanel Margin="0,6,0,0">
                                            <Button Content="Load Multiple Files" Command="{Binding BrowseMultipleFilesCommand}" />
                                            <Button Content="Load Folder" Command="{Binding BrowseFolderCommand}" />
                                            <Button Content="Apply Same Password" Command="{Binding ApplySamePasswordCommand}" />
                                            <Button Content="Generate Passphrases" Command="{Binding GeneratePasswordsCommand}" />
                                            <Button Content="Import CSV/Excel" Command="{Binding ImportMappingCommand}" />
                                            <Button Content="Export Template CSV" Command="{Binding ExportTemplateCommand}" />
                                            <Button Content="Export Batch Info CSV" Command="{Binding ExportBatchInfoCommand}" />
                                            <Button Content="Clear Passwords" Click="ProtectClearAllPasswords_OnClick" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SectionBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSingleMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Batch Grid" />
                                        <TextBlock Margin="6,0,6,8" Foreground="#FF475467" Text="{Binding BatchSummaryText}" />
                                        <WrapPanel Margin="0,0,0,8">
                                            <Button Content="Add Files" Command="{Binding AddBatchFilesCommand}" />
                                            <Button Content="Remove Selected" Command="{Binding RemoveSelectedBatchItemCommand}" />
                                            <Button Content="Refresh Grid" Command="{Binding RefreshBatchGridCommand}" />
                                            <Button Content="Validate Grid" Command="{Binding ValidateBatchGridCommand}" />
                                            <Button Content="Select Output Folder" Command="{Binding SelectBatchOutputFolderCommand}" />
                                        </WrapPanel>
                                        <TextBlock Margin="6,0,6,8" Foreground="#FF475467" TextWrapping="Wrap" Text="{Binding BatchOutputFolder}" />
                                        <TextBlock Margin="6,0,6,8" Foreground="#FF475467" TextWrapping="Wrap" Text="{Binding BatchValidationText}" />
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  ItemsSource="{Binding BatchItems}"
                                                  SelectedItem="{Binding SelectedBatchItem}"
                                                  MinHeight="240">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                            <Setter Property="Background" Value="#FFFEECEC" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasValidationWarning}" Value="True">
                                                            <Setter Property="Background" Value="#FFFFF7E8" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="180" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Input Path" Binding="{Binding InputPath}" Width="*" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Output Path" Binding="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                <DataGridTemplateColumn Header="Password" Width="260">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="34" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Style="{StaticResource InlinePasswordHostStyle}"
                                                                        Margin="0"
                                                                        Padding="0">
                                                                    <Grid>
                                                                <TextBox Text="{Binding MaskedPassword, Mode=OneWay}"
                                                                         IsReadOnly="True"
                                                                         IsReadOnlyCaretVisible="False"
                                                                         Cursor="Arrow">
                                                                    <TextBox.Style>
                                                                        <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBox.Style>
                                                                </TextBox>
                                                                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">
                                                                    <TextBox.Style>
                                                                        <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBox.Style>
                                                                </TextBox>
                                                                <Button Style="{StaticResource EyeButtonStyle}"
                                                                        Grid.Column="1"
                                                                        Command="{Binding DataContext.ToggleBatchItemPasswordVisibilityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Viewbox Width="16" Height="16">
                                                                        <Canvas Width="24" Height="24">
                                                                            <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                                                  Stroke="#FF475467"
                                                                                  StrokeThickness="1.8"
                                                                                  Fill="Transparent" />
                                                                            <Ellipse Canvas.Left="8.2"
                                                                                     Canvas.Top="8.2"
                                                                                     Width="7.6"
                                                                                     Height="7.6"
                                                                                     Stroke="#FF475467"
                                                                                     StrokeThickness="1.8"
                                                                                     Fill="Transparent" />
                                                                        </Canvas>
                                                                    </Viewbox>
                                                                </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="300" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Permission Restrictions" />
                                        <WrapPanel>
                                            <CheckBox Content="Allow print" IsChecked="{Binding AllowPrint}" />
                                            <CheckBox Content="Allow HQ print" IsChecked="{Binding AllowFullQualityPrint}" />
                                            <CheckBox Content="Allow modify" IsChecked="{Binding AllowModifyDocument}" />
                                            <CheckBox Content="Allow extract" IsChecked="{Binding AllowExtractContent}" />
                                            <CheckBox Content="Allow annotations" IsChecked="{Binding AllowAnnotations}" />
                                            <CheckBox Content="Allow form fill" IsChecked="{Binding AllowFormsFill}" />
                                            <CheckBox Content="Allow page assemble" IsChecked="{Binding AllowAssembleDocument}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <StackPanel>
                                        <Button Width="170"
                                                HorizontalAlignment="Left"
                                                Content="Protect PDF"
                                                Command="{Binding ProtectCommand}" />
                                        <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding StatusMessage}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Files" />
                                <ListBox Grid.Row="1"
                                         Margin="0,8,0,8"
                                         ItemsSource="{Binding RecentFiles}"
                                         SelectedItem="{Binding SelectedRecentFile}"
                                         DisplayMemberPath="DisplayName" />
                                <Button Grid.Row="2"
                                        Content="Use Selected Recent"
                                        Command="{Binding UseRecentFileCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Page Organizer">
                    <Grid Margin="8" DataContext="{Binding Split}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Style="{StaticResource SectionBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Input PDF:" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding BrowseInputCommand}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Output folder:" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseOutputFolderCommand}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0,0,16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Page Thumbnails" />
                                    <TextBlock Margin="12,0,0,8"
                                               VerticalAlignment="Center"
                                               Foreground="#FF667085"
                                               Text="{Binding PageCountText}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button Content="Extract Selected" Command="{Binding ExtractSelectedCommand}" />
                                    <Button Content="Remove Selected" Command="{Binding RemoveSelectedPagesCommand}" />
                                    <Button Content="Rotate Left" Command="{Binding RotateLeftCommand}" />
                                    <Button Content="Rotate Right" Command="{Binding RotateRightCommand}" />
                                </WrapPanel>

                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Margin="6,0,6,8"
                                           Foreground="#FF475467"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />

                                <ListBox Grid.Row="2"
                                         Grid.ColumnSpan="2"
                                         x:Name="SplitPageList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionMode="Extended"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemsSource="{Binding Pages}"
                                         AllowDrop="True"
                                         PreviewMouseMove="SplitPageList_OnPreviewMouseMove"
                                         DragOver="SplitPageList_OnDragOver"
                                         Drop="SplitPageList_OnDrop">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                            <Setter Property="Margin" Value="6" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10"
                                                    Width="140"
                                                    CornerRadius="14"
                                                    BorderThickness="1.5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF9FBFC" />
                                                        <Setter Property="BorderBrush" Value="#FFD6DFE5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#FFE7F4FA" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Height="132" Margin="0,0,0,10">
                                                        <Border Width="84"
                                                                Height="112"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Background="White"
                                                                BorderBrush="#FFCED7DE"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                RenderTransformOrigin="0.5,0.5">
                                                            <Border.RenderTransform>
                                                                <RotateTransform Angle="{Binding Rotation}" />
                                                            </Border.RenderTransform>
                                                            <Grid>
                                                                <Image Source="{Binding Thumbnail}"
                                                                       Stretch="Uniform"
                                                                       Margin="6">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="28"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#FF98A2B3"
                                                                           Text="{Binding PageNumber}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,6,6,0"
                                                                Padding="6,2"
                                                                Background="#FF0B6E99"
                                                                CornerRadius="10">
                                                            <TextBlock Foreground="White"
                                                                       FontSize="11"
                                                                       Text="{Binding RotationLabel}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding PageLabel}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selection Presets" />
                                    <WrapPanel>
                                        <RadioButton Content="Every page" IsChecked="{Binding IsEveryPagePreset}" />
                                        <RadioButton Content="Odd pages" IsChecked="{Binding IsOddPagesPreset}" />
                                        <RadioButton Content="Even pages" IsChecked="{Binding IsEvenPagesPreset}" />
                                        <RadioButton Content="Page list" IsChecked="{Binding IsPageListPreset}" />
                                        <RadioButton Content="Custom selection" IsChecked="{Binding IsCustomSelectionPreset}" />
                                    </WrapPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Margin="6" VerticalAlignment="Center" Text="Pages:" />
                                        <TextBox Grid.Column="1"
                                                 Width="140"
                                                 HorizontalAlignment="Left"
                                                 Text="{Binding PageSelectionInput, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2"
                                                Width="100"
                                                Content="Apply"
                                                Command="{Binding ApplySelectionPresetCommand}" />
                                    </Grid>
                                    <WrapPanel>
                                        <Button Content="Select All" Command="{Binding SelectAllPagesCommand}" />
                                        <Button Content="Clear Selection" Command="{Binding ClearPageSelectionCommand}" />
                                    </WrapPanel>
                                    <TextBlock Margin="6,6,6,0"
                                               Foreground="#FF667085"
                                               Text="Example: 1, 3-8, 15" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Output Strategy" />
                                    <RadioButton Content="Separate files per page" IsChecked="{Binding IsSeparateFilesStrategy}" />
                                    <RadioButton Content="Group contiguous ranges" IsChecked="{Binding IsRangeFilesStrategy}" />
                                    <RadioButton Content="Single file from selected pages" IsChecked="{Binding IsSingleFileStrategy}" />
                                    <TextBlock Margin="6,8,6,0"
                                               Foreground="#FF667085"
                                               TextWrapping="Wrap"
                                               Text="{Binding ValidationMessage}" />
                                    <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding StatusMessage}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}" Margin="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Files" />
                                    <ListBox Grid.Row="1"
                                             Margin="0,8,0,8"
                                             ItemsSource="{Binding RecentFiles}"
                                             SelectedItem="{Binding SelectedRecentFile}"
                                             DisplayMemberPath="DisplayName" />
                                    <Button Grid.Row="2"
                                            Content="Use Selected Recent"
                                            Command="{Binding UseRecentFileCommand}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0,0,16,0"
                                MaxHeight="220">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Text="Preview Naming Pattern" />
                                <TextBlock Grid.Row="1"
                                           Margin="6,0,6,4"
                                           Foreground="#FF475467"
                                           Text="{Binding OutputPreviewSummary}" />
                                <DataGrid Grid.Row="2"
                                          Margin="6,4,6,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding OutputPreviewItems}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" />
                                        <DataGridTextColumn Header="Pages" Binding="{Binding PageCount}" Width="90" />
                                        <DataGridTextColumn Header="File Size" Binding="{Binding FileSizeText}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Merge PDF">
                    <Grid Margin="8" DataContext="{Binding Merge}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,14,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Text="Merge Queue" />

                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="6"
                                            Padding="8"
                                            Background="{StaticResource SubtlePanelBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="1.5"
                                            CornerRadius="12"
                                            AllowDrop="True"
                                            DragOver="MergeDropZone_OnDragOver"
                                            Drop="MergeDropZone_OnDrop">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Margin="0,0,0,4"
                                                       Foreground="#FF344054"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding QueueSummaryText}" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,0,0,8"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Use Shift/Ctrl for desktop-style multi-select, then drag pages or whole files to reorder or insert them." />
                                            <ListBox Grid.Row="2"
                                                     x:Name="MergeQueueList"
                                                     MinHeight="320"
                                                     ItemsSource="{Binding Files}"
                                                     SelectedItem="{Binding SelectedFile}"
                                                     SelectionMode="Extended"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.CanContentScroll="False"
                                                     PreviewMouseLeftButtonDown="MergeQueueList_OnPreviewMouseLeftButtonDown"
                                                     PreviewMouseLeftButtonUp="MergeQueueList_OnPreviewMouseLeftButtonUp"
                                                     PreviewMouseMove="MergeQueueList_OnPreviewMouseMove"
                                                     MouseDoubleClick="MergeQueueList_OnMouseDoubleClick"
                                                     AllowDrop="True"
                                                     DragOver="MergeQueueList_OnDragOver"
                                                     DragLeave="MergeQueueList_OnDragLeave"
                                                     Drop="MergeQueueList_OnDrop">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Margin" Value="0,0,0,6" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8"
                                                                CornerRadius="14"
                                                                BorderThickness="1.5">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#FFF9FBFC" />
                                                                    <Setter Property="BorderBrush" Value="#FFD6DFE5" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                            <Setter Property="Background" Value="#FFF0F9FF" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                                            <Setter Property="Background" Value="#FFFFF4E8" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#FFE7F4FA" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Text="{Binding FileName}" />
                                                                    <Border Grid.Column="1"
                                                                            Margin="10,0,0,0"
                                                                            Padding="8,3"
                                                                            Background="#FFF2F4F7"
                                                                            CornerRadius="10"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Foreground="#FF667085"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding PageCountText}" />
                                                                    </Border>
                                                                    <Border Grid.Column="2"
                                                                            Margin="10,0,0,0"
                                                                            Padding="10,4"
                                                                            Background="#FFEFF6FB"
                                                                            CornerRadius="12"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding ValidationMessage}" />
                                                                    </Border>
                                                                </Grid>

                                                                <ListBox Grid.Row="1"
                                                                         Margin="0,8,0,0"
                                                                         Height="144"
                                                                         ItemsSource="{Binding PageThumbnails}"
                                                                          SelectionMode="Extended"
                                                                          BorderThickness="0"
                                                                          Background="Transparent"
                                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                                         ScrollViewer.CanContentScroll="False"
                                                                         PreviewMouseLeftButtonDown="MergePageList_OnPreviewMouseLeftButtonDown"
                                                                         PreviewMouseLeftButtonUp="MergePageList_OnPreviewMouseLeftButtonUp"
                                                                         PreviewMouseMove="MergePageList_OnPreviewMouseMove"
                                                                         PreviewMouseRightButtonDown="MergePageList_OnPreviewMouseRightButtonDown"
                                                                         PreviewMouseRightButtonUp="MergePageList_OnPreviewMouseRightButtonUp"
                                                                         DragOver="MergePageList_OnDragOver"
                                                                         DragLeave="MergePageList_OnDragLeave"
                                                                         Drop="MergePageList_OnDrop"
                                                                         AllowDrop="True">
                                                                        <ListBox.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ListBox.ItemsPanel>
                                                                        <ListBox.ItemContainerStyle>
                                                                            <Style TargetType="ListBoxItem">
                                                                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                                                                <Setter Property="Margin" Value="0,0,6,0" />
                                                                                <Setter Property="Padding" Value="0" />
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Setter Property="BorderThickness" Value="0" />
                                                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                            </Style>
                                                                        </ListBox.ItemContainerStyle>
                                                                        <ListBox.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel>
                                                                                    <Grid Height="112" Margin="0,0,0,4">
                                                                                        <Border Width="76"
                                                                                                Height="98"
                                                                                                HorizontalAlignment="Center"
                                                                                                VerticalAlignment="Center"
                                                                                                Background="White"
                                                                                                BorderBrush="#FFCED7DE"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="10"
                                                                                                RenderTransformOrigin="0.5,0.5">
                                                                                            <Border.Style>
                                                                                                <Style TargetType="Border">
                                                                                                    <Setter Property="BorderBrush" Value="#FFCED7DE" />
                                                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                                            <Setter Property="BorderThickness" Value="2.5" />
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                                            <Setter Property="BorderThickness" Value="1.5" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Border.Style>
                                                                                            <Border.RenderTransform>
                                                                                                <RotateTransform Angle="{Binding Rotation}" />
                                                                                            </Border.RenderTransform>
                                                                                            <Grid>
                                                                                                <Image Source="{Binding Thumbnail}"
                                                                                                       Stretch="Uniform"
                                                                                                       Margin="4">
                                                                                                    <Image.Style>
                                                                                                        <Style TargetType="Image">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </Image.Style>
                                                                                                </Image>
                                                                                                <TextBlock HorizontalAlignment="Center"
                                                                                                           VerticalAlignment="Center"
                                                                                                           Foreground="#FF98A2B3"
                                                                                                           FontSize="16"
                                                                                                           FontWeight="SemiBold"
                                                                                                           Text="{Binding PageLabel}">
                                                                                                    <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </TextBlock.Style>
                                                                                                </TextBlock>
                                                                                            </Grid>
                                                                                        </Border>
                                                                                        <Border HorizontalAlignment="Right"
                                                                                                VerticalAlignment="Bottom"
                                                                                                Margin="0,0,8,8"
                                                                                                Width="16"
                                                                                                Height="16"
                                                                                                Background="{StaticResource SuccessBrush}"
                                                                                                CornerRadius="8">
                                                                                            <Border.Style>
                                                                                                <Style TargetType="Border">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Border.Style>
                                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center"
                                                                                                       Foreground="White"
                                                                                                       FontSize="10"
                                                                                                       FontWeight="Bold"
                                                                                                       Text="&#x2713;" />
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock HorizontalAlignment="Center"
                                                                                               FontWeight="SemiBold"
                                                                                               FontSize="11"
                                                                                               Text="{Binding PageLabel}" />
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ListBox.ItemTemplate>
                                                                </ListBox>

                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="6">
                                        <Button Content="Add Files" Command="{Binding AddFilesCommand}" />
                                        <Button Content="Merge PDF" Command="{Binding MergeCommand}" />
                                        <Button Content="Remove Selected Files" Click="MergeRemoveSelectedFiles_OnClick" />
                                        <Button Content="Rotate Left" Click="MergeRotateLeftSelectedPages_OnClick" />
                                        <Button Content="Rotate Right" Click="MergeRotateRightSelectedPages_OnClick" />
                                        <Button Content="Undo"
                                                Command="{Binding UndoCommand}"
                                                ToolTip="Undo the last queue, insert, reorder, or rotate action (Ctrl+Z)" />
                                        <Button Content="Open Output Folder" Command="{Binding OpenOutputFolderCommand}" />
                                    </StackPanel>

                                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="2" Grid.Column="1" Content="Save As" Command="{Binding BrowseOutputCommand}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" Padding="10" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,12,0"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Validation Summary" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="{Binding ValidationSummaryText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource StatusTextStyle}"
                                               Text="{Binding StatusMessage}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="File Preview" />

                                <Grid Grid.Row="1" Margin="0,8,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File name" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding PreviewFileName}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Full path" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" Text="{Binding PreviewFilePath}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Page count" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewPageCount}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File size" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewFileSize}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,0" Foreground="#FF667085" Text="Encryption" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewEncryption}" />
                                </Grid>

                                <TextBlock Grid.Row="2" Margin="0,0,0,12" Foreground="#FF475467" TextWrapping="Wrap" Text="{Binding PreviewStatus}" />

                                <Border Grid.Row="3"
                                        Style="{StaticResource SectionBorderStyle}"
                                        Margin="0,0,0,12"
                                        Padding="10"
                                        Visibility="{Binding IsPreviewPasswordPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" Text="File Password" />
                                        <TextBox Text="{Binding SelectedFile.Password, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="6,0,6,6"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding PreviewPasswordHint}" />
                                        <Button Width="130"
                                                HorizontalAlignment="Left"
                                                Content="Unlock Preview"
                                                Command="{Binding ReloadSelectedPreviewCommand}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="4" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,8" Text="Job Report" />
                                <DataGrid Grid.Row="5"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding ReportEntries}"
                                          SelectedItem="{Binding SelectedReportItem}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimestampLocal, StringFormat=HH:mm:ss}" Width="90" />
                                        <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="80" />
                                        <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <StatusBar Grid.Row="1"
                   Margin="0,14,0,0"
                   Padding="10,6"
                   Background="{StaticResource PanelBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="1">
            <StatusBarItem Width="Auto">
                <TextBlock FontWeight="SemiBold" Text="{Binding Status.StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Width="260">
                <ProgressBar Height="16"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding Status.IsIndeterminate, Mode=OneWay}"
                             Value="{Binding Status.ProgressValue, Mode=OneWay}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding Status.IsBusy, StringFormat=Busy: {0}}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

