                                                                <Button Style="{StaticResource EyeButtonStyle}"
                                                                        Grid.Column="1"
                                                                        Command="{Binding DataContext.ToggleBatchItemPasswordVisibilityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Viewbox Width="16" Height="16">
                                                                        <Canvas Width="24" Height="24">
                                                                            <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                                                  Stroke="#FF475467"
                                                                                  StrokeThickness="1.8"
                                                                                  Fill="Transparent" />
                                                                            <Ellipse Canvas.Left="8.2"
                                                                                     Canvas.Top="8.2"
                                                                                     Width="7.6"
                                                                                     Height="7.6"
                                                                                     Stroke="#FF475467"
                                                                                     StrokeThickness="1.8"
                                                                                     Fill="Transparent" />
                                                                        </Canvas>
                                                                    </Viewbox>
                                                                </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Owner Password" Width="240">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="34" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Style="{StaticResource InlinePasswordHostStyle}"
                                                                        Margin="0"
                                                                        Padding="0">
                                                                    <Grid>
                                                                        <TextBox Text="{Binding MaskedOwnerPassword, Mode=OneWay}"
                                                                                 IsReadOnly="True"
                                                                                 IsReadOnlyCaretVisible="False"
                                                                                 Cursor="Arrow">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                        <TextBox Text="{Binding OwnerPassword, UpdateSourceTrigger=PropertyChanged}">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsOwnerPasswordVisible}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                        <Button Style="{StaticResource EyeButtonStyle}"
                                                                                Grid.Column="1"
                                                                                Command="{Binding DataContext.ToggleBatchItemOwnerPasswordVisibilityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                                CommandParameter="{Binding}">
                                                                            <Viewbox Width="16" Height="16">
                                                                                <Canvas Width="24" Height="24">
                                                                                    <Path Data="M1,12 C4,6 8,4 12,4 C16,4 20,6 23,12 C20,18 16,20 12,20 C8,20 4,18 1,12 Z"
                                                                                          Stroke="#FF475467"
                                                                                          StrokeThickness="1.8"
                                                                                          Fill="Transparent" />
                                                                                    <Ellipse Canvas.Left="8.2"
                                                                                             Canvas.Top="8.2"
                                                                                             Width="7.6"
                                                                                             Height="7.6"
                                                                                             Stroke="#FF475467"
                                                                                             StrokeThickness="1.8"
                                                                                             Fill="Transparent" />
                                                                                </Canvas>
                                                                            </Viewbox>
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="300" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SectionBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUnlockAction}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Permission Restrictions" />
                                        <WrapPanel>
                                            <CheckBox Content="Allow print" IsChecked="{Binding AllowPrint}" />
                                            <CheckBox Content="Allow HQ print" IsChecked="{Binding AllowFullQualityPrint}" />
                                            <CheckBox Content="Allow modify" IsChecked="{Binding AllowModifyDocument}" />
                                            <CheckBox Content="Allow extract" IsChecked="{Binding AllowExtractContent}" />
                                            <CheckBox Content="Allow annotations" IsChecked="{Binding AllowAnnotations}" />
                                            <CheckBox Content="Allow form fill" IsChecked="{Binding AllowFormsFill}" />
                                            <CheckBox Content="Allow page assemble" IsChecked="{Binding AllowAssembleDocument}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Files" />
                                <ListBox Grid.Row="1"
                                         Margin="0,8,0,8"
                                         ItemsSource="{Binding RecentFiles}"
                                         SelectedItem="{Binding SelectedRecentFile}"
                                         DisplayMemberPath="DisplayName" />
                                <Button Grid.Row="2"
                                        Content="Use Selected Recent"
                                        Command="{Binding UseRecentFileCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Page Organizer">
                    <Grid Margin="8" DataContext="{Binding Split}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="340" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Style="{StaticResource SectionBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Input PDF:" />
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Width="112"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource UtilityActionButtonStyle}"
                                            Content="Browse"
                                            Command="{Binding BrowseInputCommand}" />
                                </Grid>

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Output folder:" />
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Width="112"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource UtilityActionButtonStyle}"
                                            Content="Browse"
                                            Command="{Binding BrowseOutputFolderCommand}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0,0,16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Page Thumbnails" />
                                    <TextBlock Margin="12,0,0,8"
                                               VerticalAlignment="Center"
                                               Foreground="#FF667085"
                                               Text="{Binding PageCountText}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource ActionToolbarStyle}">
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="Extract Selected"
                                            Command="{Binding ExtractSelectedCommand}" />
                                    <Button Style="{StaticResource DangerActionButtonStyle}"
                                            Content="Remove Selected"
                                            Command="{Binding RemoveSelectedPagesCommand}" />
                                    <Button Style="{StaticResource UtilityActionButtonStyle}"
                                            Content="Rotate Left"
                                            Command="{Binding RotateLeftCommand}" />
                                    <Button Style="{StaticResource UtilityActionButtonStyle}"
                                            Content="Rotate Right"
                                            Command="{Binding RotateRightCommand}" />
                                </WrapPanel>

                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Margin="6,0,6,8"
                                           Foreground="#FF475467"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />

                                <ListBox Grid.Row="2"
                                         Grid.ColumnSpan="2"
                                         x:Name="SplitPageList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionMode="Extended"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemsSource="{Binding Pages}"
                                         AllowDrop="True"
                                         PreviewMouseMove="SplitPageList_OnPreviewMouseMove"
                                         DragOver="SplitPageList_OnDragOver"
                                         DragLeave="SplitPageList_OnDragLeave"
                                         Drop="SplitPageList_OnDrop">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                            <Setter Property="Margin" Value="6" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                    <Setter Property="Margin" Value="6,6,28,6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10"
                                                    Width="140"
                                                    CornerRadius="14"
                                                    BorderThickness="1.5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF9FBFC" />
                                                        <Setter Property="BorderBrush" Value="#FFD6DFE5" />
                                                        <Setter Property="Effect" Value="{x:Null}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#660B6E99"
                                                                                          BlurRadius="12"
                                                                                          ShadowDepth="0"
                                                                                          Opacity="1" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#FFE7F4FA" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Height="132" Margin="0,0,0,10">
                                                        <Border Width="84"
                                                                Height="112"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Background="White"
                                                                BorderBrush="#FFCED7DE"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                RenderTransformOrigin="0.5,0.5">
                                                            <Border.RenderTransform>
                                                                <RotateTransform Angle="{Binding Rotation}" />
                                                            </Border.RenderTransform>
                                                            <Grid>
                                                                <Image Source="{Binding Thumbnail}"
                                                                       Stretch="Uniform"
                                                                       Margin="6">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="28"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#FF98A2B3"
                                                                           Text="{Binding PageNumber}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                        <Rectangle Width="4"
                                                                   RadiusX="2"
                                                                   RadiusY="2"
                                                                   Fill="{StaticResource AccentBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,12,-16,12"
                                                                   Visibility="Collapsed">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Setter Property="Height" Value="92" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                        </Rectangle>
                                                    </Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding PageLabel}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selection Presets" />
                                    <Border Style="{StaticResource SegmentedHostStyle}" Margin="0,4,0,0">
                                        <WrapPanel>
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Every page" IsChecked="{Binding IsEveryPagePreset}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Odd pages" IsChecked="{Binding IsOddPagesPreset}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Even pages" IsChecked="{Binding IsEvenPagesPreset}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Page list" IsChecked="{Binding IsPageListPreset}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Custom selection" IsChecked="{Binding IsCustomSelectionPreset}" />
                                        </WrapPanel>
                                    </Border>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="116" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"
                                                   Text="Pages:" />
                                        <TextBox Grid.Column="1"
                                                 Height="34"
                                                 Text="{Binding PageSelectionInput, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="3"
                                                Width="116"
                                                Style="{StaticResource UtilityActionButtonStyle}"
                                                Content="Apply Preset"
                                                Command="{Binding ApplySelectionPresetCommand}" />
                                    </Grid>
                                    <WrapPanel Style="{StaticResource ActionToolbarStyle}">
                                        <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Select All" Command="{Binding SelectAllPagesCommand}" />
                                        <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Clear Selection" Command="{Binding ClearPageSelectionCommand}" />
                                    </WrapPanel>
                                    <TextBlock Margin="6,6,6,0"
                                               Foreground="#FF667085"
                                               Text="Example: 1, 3-8, 15" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Output Strategy" />
                                    <Border Style="{StaticResource SegmentedHostStyle}" Margin="0,4,0,0">
                                        <WrapPanel>
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Separate files per page" IsChecked="{Binding IsSeparateFilesStrategy}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Group contiguous ranges" IsChecked="{Binding IsRangeFilesStrategy}" />
                                            <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Single file from selected pages" IsChecked="{Binding IsSingleFileStrategy}" />
                                        </WrapPanel>
                                    </Border>
                                    <TextBlock Margin="6,8,6,0"
                                               Foreground="#FF667085"
                                               TextWrapping="Wrap"
                                               Text="{Binding ValidationMessage}" />
                                    <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding StatusMessage}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Document Access" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#FF667085" Text="Encryption" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DocumentEncryptionText}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Foreground="#FF667085" Text="Access" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DocumentPasswordHint}" />
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding IsDocumentPasswordPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="File password" />
                                        <TextBox Margin="0,8,0,0"
                                                 Text="{Binding DocumentPassword, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Margin="0,10,0,0" Text="Owner password" />
                                        <TextBox Margin="0,8,0,0"
                                                 Text="{Binding DocumentOwnerPassword, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Width="132"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource UtilityActionButtonStyle}"
                                                Content="Reload Document"
                                                Command="{Binding ReloadProtectedDocumentCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0,0,16,0"
                                MaxHeight="208">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Text="Preview Naming Pattern" />
                                <TextBlock Grid.Row="1"
                                           Margin="6,0,6,4"
                                           Foreground="#FF475467"
                                           Text="{Binding OutputPreviewSummary}" />
                                <DataGrid Grid.Row="2"
                                          Margin="6,4,6,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding OutputPreviewItems}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" />
                                        <DataGridTextColumn Header="Pages" Binding="{Binding PageCount}" Width="90" />
                                        <DataGridTextColumn Header="File Size" Binding="{Binding FileSizeText}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Merge PDF">
                    <Grid Margin="8" DataContext="{Binding Merge}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="284" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,14,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Text="Merge Queue" />

                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="6"
                                            Padding="8"
                                            Background="{StaticResource SubtlePanelBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="1.5"
                                            CornerRadius="12"
                                            AllowDrop="True"
                                            DragOver="MergeDropZone_OnDragOver"
                                            Drop="MergeDropZone_OnDrop">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Margin="0,0,0,4"
                                                       Foreground="#FF344054"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding QueueSummaryText}" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,0,0,8"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Use Shift/Ctrl for desktop-style multi-select, then drag pages or whole files to reorder or insert them." />
                                            <ListBox Grid.Row="2"
                                                     x:Name="MergeQueueList"
                                                     MinHeight="320"
                                                     ItemsSource="{Binding Files}"
                                                     SelectedItem="{Binding SelectedFile}"
                                                     SelectionMode="Extended"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.CanContentScroll="False"
                                                     PreviewMouseLeftButtonDown="MergeQueueList_OnPreviewMouseLeftButtonDown"
                                                     PreviewMouseLeftButtonUp="MergeQueueList_OnPreviewMouseLeftButtonUp"
                                                     PreviewMouseMove="MergeQueueList_OnPreviewMouseMove"
                                                     MouseDoubleClick="MergeQueueList_OnMouseDoubleClick"
                                                     AllowDrop="True"
                                                     DragOver="MergeQueueList_OnDragOver"
                                                     DragLeave="MergeQueueList_OnDragLeave"
                                                     Drop="MergeQueueList_OnDrop">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Margin" Value="0,0,0,6" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8"
                                                                CornerRadius="14"
                                                                BorderThickness="1.5">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#FFF9FBFC" />
                                                                    <Setter Property="BorderBrush" Value="#FFD6DFE5" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                            <Setter Property="Background" Value="#FFF0F9FF" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                                            <Setter Property="Background" Value="#FFFFF4E8" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#FFE7F4FA" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Text="{Binding FileName}" />
                                                                    <Border Grid.Column="1"
                                                                            Margin="10,0,0,0"
                                                                            Padding="8,3"
                                                                            Background="#FFF2F4F7"
                                                                            CornerRadius="10"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Foreground="#FF667085"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding PageCountText}" />
                                                                    </Border>
                                                                    <Border Grid.Column="2"
                                                                            Margin="10,0,0,0"
                                                                            Padding="10,4"
                                                                            Background="#FFEFF6FB"
                                                                            CornerRadius="12"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding ValidationMessage}" />
                                                                    </Border>
                                                                </Grid>

                                                                <ListBox Grid.Row="1"
                                                                         Margin="0,8,0,0"
                                                                         Height="166"
                                                                         ItemsSource="{Binding PageThumbnails}"
                                                                         SelectionMode="Extended"
                                                                         BorderThickness="0"
                                                                          Background="Transparent"
                                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                                         ScrollViewer.CanContentScroll="False"
                                                                         PreviewMouseLeftButtonDown="MergePageList_OnPreviewMouseLeftButtonDown"
                                                                         PreviewMouseLeftButtonUp="MergePageList_OnPreviewMouseLeftButtonUp"
                                                                         PreviewMouseMove="MergePageList_OnPreviewMouseMove"
                                                                         PreviewMouseRightButtonDown="MergePageList_OnPreviewMouseRightButtonDown"
                                                                         PreviewMouseRightButtonUp="MergePageList_OnPreviewMouseRightButtonUp"
                                                                         DragOver="MergePageList_OnDragOver"
                                                                         DragLeave="MergePageList_OnDragLeave"
                                                                         Drop="MergePageList_OnDrop"
                                                                         AllowDrop="True">
                                                                        <ListBox.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ListBox.ItemsPanel>
                                                                        <ListBox.ItemContainerStyle>
                                                                            <Style TargetType="ListBoxItem">
                                                                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                                                                <Setter Property="Margin" Value="0,0,8,0" />
                                                                                <Setter Property="Padding" Value="0" />
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Setter Property="BorderThickness" Value="0" />
                                                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                                        <Setter Property="Margin" Value="0,0,30,0" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ListBox.ItemContainerStyle>
                                                                        <ListBox.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel>
                                                                                    <Grid Height="132"
                                                                                          Margin="0,0,0,4">
                                                                                        <Border Width="92"
                                                                                                Height="118"
                                                                                                HorizontalAlignment="Center"
                                                                                                VerticalAlignment="Center"
                                                                                                Background="White"
                                                                                                BorderBrush="#FFCED7DE"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="10"
                                                                                                RenderTransformOrigin="0.5,0.5">
                                                                                        <Border.Style>
                                                                                            <Style TargetType="Border">
                                                                                                <Setter Property="BorderBrush" Value="#FFCED7DE" />
                                                                                                <Setter Property="BorderThickness" Value="1" />
                                                                                                <Setter Property="Effect" Value="{x:Null}" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                                        <Setter Property="BorderThickness" Value="2.5" />
                                                                                                        <Setter Property="Effect">
                                                                                                            <Setter.Value>
                                                                                                                <DropShadowEffect Color="#660B6E99"
                                                                                                                                  BlurRadius="12"
                                                                                                                                  ShadowDepth="0"
                                                                                                                                  Opacity="1" />
                                                                                                            </Setter.Value>
                                                                                                        </Setter>
                                                                                                    </DataTrigger>
                                                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                                            <Setter Property="BorderThickness" Value="1.5" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Border.Style>
                                                                                            <Border.RenderTransform>
                                                                                                <RotateTransform Angle="{Binding Rotation}" />
                                                                                            </Border.RenderTransform>
                                                                                            <Grid>
                                                                                                <Image Source="{Binding Thumbnail}"
                                                                                                       Stretch="Uniform"
                                                                                                       Margin="4">
                                                                                                    <Image.Style>
                                                                                                        <Style TargetType="Image">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </Image.Style>
                                                                                                </Image>
                                                                                                <TextBlock HorizontalAlignment="Center"
                                                                                                           VerticalAlignment="Center"
                                                                                                           Foreground="#FF98A2B3"
                                                                                                           FontSize="16"
                                                                                                           FontWeight="SemiBold"
                                                                                                           Text="{Binding PageLabel}">
                                                                                                    <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </TextBlock.Style>
                                                                                                </TextBlock>
                                                                                            </Grid>
                                                                                        </Border>
                                                                                        <Rectangle Width="4"
                                                                                                   RadiusX="2"
                                                                                                   RadiusY="2"
                                                                                                   Fill="{StaticResource AccentBrush}"
                                                                                                   HorizontalAlignment="Right"
                                                                                                   Margin="0,12,-17,12"
                                                                                                   Visibility="Collapsed">
                                                                                            <Rectangle.Style>
                                                                                                <Style TargetType="Rectangle">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Setter Property="Height" Value="98" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Rectangle.Style>
                                                                                        </Rectangle>
                                                                                        <Border HorizontalAlignment="Right"
                                                                                                VerticalAlignment="Bottom"
                                                                                                Margin="0,0,6,6"
                                                                                                Width="18"
                                                                                                Height="18"
                                                                                                Background="{StaticResource SuccessBrush}"
                                                                                                CornerRadius="9">
                                                                                            <Border.Style>
                                                                                                <Style TargetType="Border">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Border.Style>
                                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center"
                                                                                                       Foreground="White"
                                                                                                       FontSize="11"
                                                                                                       FontWeight="Bold"
                                                                                                       Text="&#x2713;" />
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock HorizontalAlignment="Center"
                                                                                               FontWeight="SemiBold"
                                                                                               FontSize="12"
                                                                                               Text="{Binding PageLabel}" />
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ListBox.ItemTemplate>
                                                                </ListBox>

                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="6,6,0,6"
                                            Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CompactFieldTitleStyle}" Text="Actions" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}"
                                                    Margin="0,10,0,0"
                                                    Content="Add Files"
                                                    Command="{Binding AddFilesCommand}" />
                                            <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Merge PDF"
                                                    Command="{Binding MergeCommand}" />
                                            <Button Style="{StaticResource DangerActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Remove Selected"
                                                    Click="MergeRemoveSelectedFiles_OnClick" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Rotate Left"
                                                    Click="MergeRotateLeftSelectedPages_OnClick" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Rotate Right"
                                                    Click="MergeRotateRightSelectedPages_OnClick" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Undo"
                                                    Command="{Binding UndoCommand}"
                                                    ToolTip="Undo the last queue, insert, reorder, or rotate action (Ctrl+Z)" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}"
                                                    Margin="0,8,0,0"
                                                    Content="Open Output Folder"
                                                    Command="{Binding OpenOutputFolderCommand}" />
                                        </StackPanel>
                                    </Border>

                                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="2"
                                            Grid.Column="1"
                                            Style="{StaticResource UtilityActionButtonStyle}"
                                            Content="Save As"
                                            Command="{Binding BrowseOutputCommand}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" Padding="8" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,12,0"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Validation Summary" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="{Binding ValidationSummaryText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource StatusTextStyle}"
                                               Text="{Binding StatusMessage}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="File Preview" />

                                <Grid Grid.Row="1" Margin="0,8,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File name" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding PreviewFileName}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Full path" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" Text="{Binding PreviewFilePath}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Page count" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewPageCount}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File size" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewFileSize}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,0" Foreground="#FF667085" Text="Encryption" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewEncryption}" />
                                </Grid>

                                <TextBlock Grid.Row="2" Margin="0,0,0,12" Foreground="#FF475467" TextWrapping="Wrap" Text="{Binding PreviewStatus}" />

                                <Border Grid.Row="3"
                                        Style="{StaticResource SectionBorderStyle}"
                                        Margin="0,0,0,12"
                                        Padding="10"
                                        Visibility="{Binding IsPreviewPasswordPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" Text="File Password" />
                                        <TextBox Text="{Binding SelectedFile.Password, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="6,0,6,6"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding PreviewPasswordHint}" />
                                        <Button Width="130"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource UtilityActionButtonStyle}"
                                                Content="Unlock Preview"
                                                Command="{Binding ReloadSelectedPreviewCommand}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="4" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,8" Text="Job Report" />
                                <DataGrid Grid.Row="5"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding ReportEntries}"
                                          SelectedItem="{Binding SelectedReportItem}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimestampLocal, StringFormat=HH:mm:ss}" Width="90" />
                                        <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="80" />
                                        <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Compress PDF">
                    <Grid Margin="8" DataContext="{Binding Compress}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,12,0">
                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Compression Mode" />
                                        <Border Style="{StaticResource SegmentedHostStyle}" Margin="0,4,0,0">
                                            <UniformGrid Columns="2">
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Single file" IsChecked="{Binding IsSingleMode}" />
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Multiple files" IsChecked="{Binding IsBatchMode}" />
                                            </UniformGrid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}"
                                        Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Input PDF:" />
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding BrowseInputCommand}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Output PDF:" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="1" Grid.Column="2" Content="Save As" Command="{Binding BrowseOutputCommand}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}"
                                        Visibility="{Binding IsBatchMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Compression Queue" />
                                        <WrapPanel Margin="0,0,0,6" Style="{StaticResource ActionToolbarStyle}">
                                            <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Load Multiple Files" Command="{Binding LoadMultipleFilesCommand}" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Add Files" Command="{Binding AddBatchFilesCommand}" />
                                            <Button Style="{StaticResource DangerActionButtonStyle}" Content="Remove Selected" Command="{Binding RemoveSelectedBatchItemCommand}" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Select Output Folder" Command="{Binding SelectOutputFolderCommand}" />
                                            <Button Style="{StaticResource UtilityActionButtonStyle}" Content="Retry Failed Items" Command="{Binding RetryFailedItemsCommand}" />
                                            <Button Style="{StaticResource DangerActionButtonStyle}" Content="Cancel" Command="{Binding CancelBatchCommand}" />
                                        </WrapPanel>
                                        <TextBlock Margin="4,0,4,8"
                                                   Foreground="#FF475467"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SharedOutputFolder}" />
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  ItemsSource="{Binding BatchItems}"
                                                  SelectedItem="{Binding SelectedBatchItem}"
                                                  MinHeight="240">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="180" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Input Path" Binding="{Binding InputPath}" Width="*" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Output Path" Binding="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                <DataGridTextColumn Header="Original Size" Binding="{Binding OriginalSizeText}" Width="110" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Result Size" Binding="{Binding ResultSizeText}" Width="110" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="220" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Compression Profile" />
                                        <Border Grid.Row="1" Style="{StaticResource SegmentedHostStyle}" Margin="0,0,0,8">
                                            <UniformGrid Columns="4">
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="25%" IsChecked="{Binding IsPreset25}" />
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="50%" IsChecked="{Binding IsPreset50}" />
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="70%" IsChecked="{Binding IsPreset70}" />
                                                <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}" Content="Custom" IsChecked="{Binding IsCustomCompression}" />
                                            </UniformGrid>
                                        </Border>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    TickFrequency="5"
                                                    IsSnapToTickEnabled="True"
                                                    Margin="4,0,8,0"
                                                    Value="{Binding CompressionLevel}" />
                                            <Border Grid.Column="1"
                                                    Margin="0,0,4,0"
                                                    Padding="8,4"
                                                    Background="#FFF2F4F7"
                                                    CornerRadius="10"
                                                    VerticalAlignment="Center">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CompressionLevel, StringFormat={}{0}%}" />
                                            </Border>
                                        </Grid>
                                        <StackPanel Grid.Row="3" Margin="4,8,4,0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding CompressionProfileLabel}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#FF667085"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding CompressionHint}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionBorderStyle}"
                                Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Compression Actions" />
                                <Button Grid.Row="1"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="Compress PDF"
                                        Command="{Binding CompressCommand}" />

                                <Border Grid.Row="2"
                                        Margin="0,12,0,0"
                                        Background="{StaticResource SubtlePanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Before / After" />
                                        <TextBlock Margin="0,6,0,12"
                                                   Foreground="#FF667085"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding PreviewContextLabel}" />

                                        <TextBlock FontWeight="SemiBold" Text="Before Compression" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File name" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding PreviewFileName}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Foreground="#FF667085" Text="File size" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewOriginalSize}" />
                                        </Grid>

                                        <Separator Margin="0,12,0,12" />

                                        <TextBlock FontWeight="SemiBold" Text="After Compression" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="File size" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewResultSize}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Saved" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewSavedText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Method used" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" Text="{Binding PreviewMethodUsed}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" Foreground="#FF667085" Text="Rasterized" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding PreviewRasterizedPages}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,0" Foreground="#FF667085" Text="Color mode" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewColorMode}" />
                                        </Grid>

                                        <Separator Margin="0,12,0,12" />

                                        <TextBlock FontWeight="SemiBold" Text="Preflight Summary" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#FF475467"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding PreviewPreflightSummary}" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Risk Warnings" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding PreviewRiskWarnings}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="3"
                                           Style="{StaticResource StatusTextStyle}"
                                           Margin="0,12,0,0"
                                           Text="{Binding StatusMessage}" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="About">
                    <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,0,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="PDF Tool v1.02" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="PDF Tool v1.02 is a desktop utility built on top of the open-source PDFsharp library. This application was created to provide practical PDF workflows such as protection, page organization, merging, and compression in a simple WPF interface." />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="Special thanks to the PDFsharp contributors and maintainers. Their work makes this project possible, and this application gratefully builds on that foundation." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Usage Notice" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="PDF Tool is provided free of charge. You may use it without prior permission for personal, educational, or internal work, but you may not sell, license for profit, redistribute commercially, or otherwise commercialize this software in any form." />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="This program is distributed in the hope that it will be useful, but WITHOUT ANY WARRANTY, including without the implied warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Contact" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               TextWrapping="Wrap"
                                               Text="For support, feedback, or licensing questions, please contact:" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontWeight="SemiBold"
                                               Text="NamBuiHuu12.12@gmail.com" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <StatusBar Grid.Row="1"
                   Margin="0,14,0,0"
                   Padding="10,6"
                   Background="{StaticResource PanelBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="1">
            <StatusBarItem Width="Auto">
                <TextBlock FontWeight="SemiBold" Text="{Binding Status.StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Width="260">
                <ProgressBar Height="16"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding Status.IsIndeterminate, Mode=OneWay}"
                             Value="{Binding Status.ProgressValue, Mode=OneWay}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding Status.IsBusy, StringFormat=Busy: {0}}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

